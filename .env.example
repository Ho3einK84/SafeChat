APP_NAME=SafeChat
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://example.com

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,safechat
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=safechat
DB_USERNAME=safechat
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# SafeChat-specific
ENCRYPTION_KEY=change-me-to-a-random-32-plus-character-string
MSG_LIMIT=50
MAX_MSG_LENGTH=2000
RATE_LIMIT_WINDOW=60
RATE_LIMIT_SEND=30
RATE_LIMIT_UNLOCK=10
ADMIN_DEVICE_IDS=
SAFECHAT_SESSION_LIFETIME=86400
MAX_UPLOAD_SIZE=5242880
SAFECHAT_LOG_LEVEL=warning
SAFECHAT_VERSION=0.1.0
SAFECHAT_INSTALL_ENABLED=false
SAFECHAT_INSTALL_TOKEN=
SAFECHAT_INSTALL_MARKER=
